{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./",


    "baseUrl": "./src",
    "types": ["node"],
    "paths": {
      "*": ["node_modules/*", "*"],
      "shared/*": ["shared/*"]
    }
  },
  "include": ["src/**/*.ts", "shared/**/*.ts"],



  "exclude": ["node_modules", "dist", "prisma/migrations", "prisma.config.ts"]

}