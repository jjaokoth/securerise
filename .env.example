# Securerise (Universal Trust Layer) - example environment file
# Copy to .env (DO NOT commit secrets)

# Prisma / Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Server
# Google Cloud Run provides PORT automatically (defaulted in code)
PORT=8080

# Security
API_KEY_SECRET="replace_with_a_strong_random_secret"

# Optional: logging / environment identifiers
NODE_ENV=production

